#!/bin/bash
# pre-pre-commit: 커밋 전 수동 실행
# 1. 버전 0.0.1 증가
# 2. APK 빌드
# 3. outputs/calendar_v{version}.apk로 복사

set -e

BUILD_GRADLE="app/build.gradle.kts"
ANDROID_HOME="${ANDROID_HOME:-$HOME/android-sdk}"
export ANDROID_HOME

# 현재 버전 읽기
CURRENT_VERSION=$(grep 'versionName = ' "$BUILD_GRADLE" | sed 's/.*versionName = "\(.*\)"/\1/')
CURRENT_CODE=$(grep 'versionCode = ' "$BUILD_GRADLE" | sed 's/.*versionCode = \([0-9]*\)/\1/')

echo "현재 버전: $CURRENT_VERSION (code: $CURRENT_CODE)"

# 버전 파싱 (major.minor.patch)
IFS='.' read -r MAJOR MINOR PATCH <<< "$CURRENT_VERSION"

# patch가 없으면 0으로 설정
PATCH=${PATCH:-0}

# patch 버전 증가
NEW_PATCH=$((PATCH + 1))
NEW_VERSION="$MAJOR.$MINOR.$NEW_PATCH"
NEW_CODE=$((CURRENT_CODE + 1))

echo "새 버전: $NEW_VERSION (code: $NEW_CODE)"

# build.gradle.kts 업데이트
sed -i "s/versionCode = $CURRENT_CODE/versionCode = $NEW_CODE/" "$BUILD_GRADLE"
sed -i "s/versionName = \"$CURRENT_VERSION\"/versionName = \"$NEW_VERSION\"/" "$BUILD_GRADLE"

echo "build.gradle.kts 업데이트 완료"

# APK 빌드
echo "APK 빌드 중..."
./gradlew assembleDebug --no-daemon -q

# outputs 폴더 생성 및 APK 복사
mkdir -p outputs

# 새 APK 복사
APK_NAME="calendar_v${NEW_VERSION}.apk"
cp app/build/outputs/apk/debug/app-debug.apk "outputs/$APK_NAME"

echo "APK 생성 완료: outputs/$APK_NAME"
echo ""
echo "이제 git add -A && git commit && git push 하세요!"
